              "});\r",
              "\r",
              "pm.test(\"Created label name is correct\", function () {\r",
              "    pm.expect(jsonData.name).to.eql(pm.environment.get(\"labelName\"));\r",
              "});\r",
              "\r",
              "pm.environment.set(\"labelId\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{labelName}}\",\r\n  \"labelListVisibility\": \"labelShow\",\r\n  \"messageListVisibility\": \"show\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://gmail.googleapis.com/gmail/v1/users/me/labels",
          "protocol": "https",
          "host": [
            "gmail",
            "googleapis",
            "com"
          ],
          "path": [
