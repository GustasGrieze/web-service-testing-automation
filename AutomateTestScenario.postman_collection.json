              "\r",
              "const jsonData = pm.response.json();\r",
              "const labelId = pm.environment.get(\"labelId\");\r",
              "\r",
              "pm.test(\"Response contains labelIds array\", function () {\r",
              "    pm.expect(jsonData.labelIds).to.exist;\r",
              "    pm.expect(jsonData.labelIds).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"New label was added to the message\", function () {\r",
              "    pm.expect(jsonData.labelIds).to.include(labelId);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
