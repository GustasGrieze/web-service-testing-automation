  "item": [
    {
      "name": "Create and send a new email",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const email = \"zdynebly@gmail.com\";\r",
              "const uniqueTs = Date.now();\r",
              "\r",
              "const subject = `API Test Email ${uniqueTs}`;\r",
              "const labelName = `API_LABEL_${uniqueTs}`;\r",
              "\r",
              "const emailText =\r",
              "`From: ${email}\r",
              "To: ${email}\r",
              "Subject: ${subject}\r",
              "\r",
              "Hello from Postman automated test!`;\r",
              "\r",
              "let base64 = Buffer.from(emailText).toString(\"base64\");\r",
              "\r",
              "let base64url = base64\r",
              "  .replace(/\\+/g, \"-\")\r",
              "  .replace(/\\//g, \"_\")\r",
              "  .replace(/=+$/, \"\");\r",
              "\r",
              "pm.variables.set(\"rawMessage\", base64url);      // local/request scope\r",
              "pm.environment.set(\"subject\", subject);         // environment scope\r",
              "pm.environment.set(\"labelName\", labelName);     // environment scope\r",
              "pm.environment.set(\"testEmail\", email);         // environment scope"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Message id exists\", function () {\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "    pm.expect(jsonData.id).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Thread id exists\", function () {\r",
              "    pm.expect(jsonData.threadId).to.exist;\r",
              "    pm.expect(jsonData.threadId).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.environment.set(\"messageId\", jsonData.id);\r",
              "pm.environment.set(\"threadId\", jsonData.threadId);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"raw\": \"{{rawMessage}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://gmail.googleapis.com/gmail/v1/users/me/messages/send",
          "protocol": "https",
          "host": [
            "gmail",
            "googleapis",
            "com"
          ],
          "path": [
            "gmail",
            "v1",
            "users",
            "me",
            "messages",
            "send"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Label",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
